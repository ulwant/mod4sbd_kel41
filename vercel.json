{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "^/(css/.*|js/.*)",
      "dest": "/public/$1"
    },
    {
      "src": "^/api/(.*)",
      "dest": "/src/index.js"
    }
  ]
}
